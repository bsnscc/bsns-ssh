<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer policy. allowBackup="false" only disables CLOUD
     backup on 12+, so we also disable device-to-device transfer here: nothing in
     this app (wrapped soft-key blobs, yubikeys, fidokeys, hosts, known_hosts)
     should ever leave the device via backup or transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
