+/* libssh2_userauth_publickey_raw
+ * Like libssh2_userauth_publickey(), but the sign callback returns a COMPLETE
+ * SSH signature blob (its own format string + algorithm-specific trailer) which
+ * is sent verbatim as the userauth packet's signature, while the pubkey-algorithm
+ * field still carries the key type from pubkeydata. This lets a caller emit a
+ * signature whose internal format differs from the key type — e.g. a
+ * webauthn-sk-ecdsa-sha2-nistp256@openssh.com signature for an
+ * sk-ecdsa-sha2-nistp256@openssh.com key (FIDO2 via a WebAuthn API).
+ * [bsns.ssh: webauthn-sk support]
+ */
+LIBSSH2_API int
+libssh2_userauth_publickey_raw(LIBSSH2_SESSION *session,
+                               const char *user,
+                               const unsigned char *pubkeydata,
+                               size_t pubkeydata_len,
+                               LIBSSH2_USERAUTH_PUBLICKEY_SIGN_FUNC
+                                   ((*sign_callback)),
+                               void **abstract)
+{
+    int rc;
 
+    if(!session)
+        return LIBSSH2_ERROR_BAD_USE;
 
+    session->userauth_pblc_raw_sig = 1;
+
+    BLOCK_ADJUST(rc, session,
+                 _libssh2_userauth_publickey(session, user, strlen(user),
+                                             pubkeydata, pubkeydata_len,
+                                             sign_callback, abstract));
+    session->userauth_pblc_raw_sig = 0;
+    return rc;
+}
