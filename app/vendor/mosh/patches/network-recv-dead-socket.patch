+      got_payload = true;
+      break;
     } catch ( NetworkException & e ) {
       if ( (e.the_errno == EAGAIN)
 	   || (e.the_errno == EWOULDBLOCK) ) {
 	continue;
+      } else if ( it->fd() != sock() ) {
+	dead_socks.push_back( it->fd() );  /* dead old socket: skip and prune */
+	continue;
       } else {
 	throw;
       }
     }
+  }
 
