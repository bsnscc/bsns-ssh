+  if ( !dead_socks.empty() ) {
+    for ( std::deque< Socket >::iterator it = socks.begin();
+	  it != socks.end() && socks.size() > 1; ) {
+      if ( std::find( dead_socks.begin(), dead_socks.end(), it->fd() ) != dead_socks.end() ) {
+	it = socks.erase( it );  /* Socket dtor closes the fd */
+      } else {
+	it++;
+      }
+    }
+  }
+
