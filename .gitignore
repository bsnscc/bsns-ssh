.DS_Store

# Swift Package Manager
.build/
.swiftpm/
/Packages/
Package.resolved

# Xcode
DerivedData/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
xcuserdata/

# Generated Xcode project (XcodeGen) — regenerated from app/project.yml
*.xcodeproj/

# Vendored xcframework — built from source by app/vendor/build-cssh.sh, not committed.
app/vendor/CSSH/CSSH.xcframework/

# Never commit key material or secrets — this is a key-management tool.
*.pem
*.key
*.p12
*.mobileprovision
secrets/

# mosh: regenerable vendored source trees (fetch-mosh.sh rebuilds them)
app/vendor/mosh/protobuf/
app/vendor/mosh/mosh-src/
app/BsnsSSH.entitlements
app/Info.plist

# Internal review docs — never publish (history was scrubbed of these)
docs/*review*
docs/*-pre-public*
